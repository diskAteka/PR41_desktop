<Page x:Class="PR41.View.Stopwatch"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:converters="clr-namespace:PR41.Converters"
      xmlns:local="clr-namespace:PR41.View"
      mc:Ignorable="d" MinHeight="450" MinWidth="800"
      Title="Stopwatch">
    <Page.Resources>
        <converters:StartStopConverter x:Key="StartStopConverter"/>
    </Page.Resources>

    <Grid Background="Black">
        <Border Opacity="1" Background="LightYellow" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="5*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <StackPanel>
                        <Button Content="{Binding IsRunning, Converter={StaticResource StartStopConverter}}" 
                                Margin="10" Padding="2" FontSize="12" MinHeight="25" Command="{Binding StartStopCommand}"/>
                        <Button Content="Сброс" Margin="10" Padding="2" FontSize="12" 
                                Command="{Binding ResetCommand}" MinHeight="25"/>
                        <Button Content="Интервал" Margin="10" Padding="2" FontSize="12" 
                                Command="{Binding CommitIntervalCommand}" MinHeight="25"/>
                        <ListBox Margin="10" Padding="2" FontSize="12" ItemsSource="{Binding Intervals}"
                                 Background="White" Foreground="Black" MinHeight="280" 
                                 BorderThickness="1" BorderBrush="Black"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Column="1">
                    <TextBlock Text="{Binding ElapsedTime}" FontSize="48" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="DarkRed"/>
                </Grid>

                <Button Grid.Column="1" Content="Таймер" Height="20" Width="80" 
                        HorizontalAlignment="Right" Margin="5" VerticalAlignment="Top"
                        Click="Button_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
