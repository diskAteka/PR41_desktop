<Page x:Class="PR41.View.Timer"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR41.View"
      xmlns:converters="clr-namespace:PR41.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Timer">

    <Page.Resources>
        <converters:StartStopConverter x:Key="StartStopConverter"/>
    </Page.Resources>
        <Grid Background="Black">
        <Border Opacity="1" Background="LightYellow" Margin="10">
            <Grid>
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBox Text="{Binding TimerDuration, Mode=TwoWay}" Margin="10" Padding="2"
                             FontSize="48" FontWeight="Bold"  MinHeight="25" Foreground="DarkRed"
                             Background="LightYellow" MinWidth="250" IsEnabled="{Binding IsRunning}"/>
                        <Button MinHeight="25" Content="{Binding IsRunning, Converter={StaticResource StartStopConverter}}" 
                                Command="{Binding StartStopCommand}" Width="100" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
